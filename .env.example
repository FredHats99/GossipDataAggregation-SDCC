# Copy to .env and customize for your local environment

APP_IMAGE=gossip-agg:local
DOCKERFILE_PATH=deployments/Dockerfile
GO_VERSION=1.24
QUALITY_GATE_PROFILE=standard
ENABLE_RACE_TESTS=true
ENABLE_GOLANGCI_LINT=true

CLUSTER_NAME=gossip-local
GOSSIP_PORT=7000
API_PORT_BASE=18080
GOSSIP_INTERVAL_MS=1000
ANTI_ENTROPY_INTERVAL_MS=15000
FANOUT=2
GOSSIP_MODE=push-pull
PEER_SELECTION_POLICY=random_alive

# Non-functional targets (Step 0 lock-in)
TARGET_CLUSTER_SIZE_DEV=3
TARGET_CLUSTER_SIZE_CI=5
TARGET_CLUSTER_SIZE_PERF=10
CONVERGENCE_EXPECTATION=eventual
CONVERGENCE_SLO_PERCENTILE=95
CONVERGENCE_SLO_SECONDS=5
CONVERGENCE_SLO_CLUSTER_SIZE=5
FAULT_MODEL_STRATEGY=phased
FAULT_MODEL_PHASE_1=crash_restart
FAULT_MODEL_PHASE_2=packet_loss_delay
FAULT_MODEL_PHASE_3=partition_heal

NODE1_ID=node1
NODE2_ID=node2
NODE3_ID=node3

NODE1_HOST=node1
NODE2_HOST=node2
NODE3_HOST=node3

SEED_NODES=node1:7000,node2:7000,node3:7000
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SAMPLE_SUCCESS_RATE=1.0
